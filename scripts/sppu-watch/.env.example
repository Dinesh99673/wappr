# ─── What to look for ────────────────────────────────────────────────────────
# Course Name is matched against the dashboard table exactly, ignoring case and
# collapsing runs of whitespace. Row order is never relied on.
COURSE_NAME=B.E.(2019 PAT.) SUMMER SESSION 2026

# Your credentials for the result form. Both are required.
SEAT_NO=
MOTHER_NAME=

# ─── Polling ─────────────────────────────────────────────────────────────────
# Wait between attempts. The portal is slow and gets hammered on result day —
# don't set this below ~5m unless you enjoy timeouts.
CHECK_INTERVAL=10m

# Give up after this many consecutive failures (0 = never give up).
MAX_ATTEMPTS=0

# ─── Notification (via your local Wappr instance) ─────────────────────────────
# Full international number, no "+". Leave blank to disable WhatsApp notify.
NOTIFY_NUMBER=
WAPPR_BASE_URL=http://localhost:3000
# Only needed if you set API_TOKEN in Wappr's own .env.
WAPPR_API_TOKEN=

# Host that Wappr can reach this script on to pull the screenshot attachment.
# 127.0.0.1 is right when Wappr runs via `npm start` on this machine.
# Use host.docker.internal if Wappr runs in Docker.
ATTACH_HOST=127.0.0.1

# ─── Browser ─────────────────────────────────────────────────────────────────
# "chrome" / "msedge" use your installed browser (no extra download).
# Leave blank to use Playwright's bundled Chromium (npx playwright install chromium).
BROWSER_CHANNEL=chrome
HEADLESS=false

# ─── Captcha ─────────────────────────────────────────────────────────────────
# Required. The portal's captcha is a 5-character image; the page only holds an
# encrypted token, so the image has to actually be read. Claude transcribes it,
# and each guess is checked against the portal's own validator before submitting,
# so a misread just refreshes and retries instead of failing the attempt.
# NOTE: this file IS committed (see the !.env.example rule in .gitignore).
# Put the real key in .env, which is gitignored. Never here.
ANTHROPIC_API_KEY=
CAPTCHA_ATTEMPTS=4
