# Wappr configuration

# SQLite database, resolved relative to prisma/ (so this lands at data/app.db).
DATABASE_URL="file:../data/app.db"

# Bulk send pacing is set per-job on the Bulk page, not here.

# QR login timeout (ms) before a pending login is torn down.
QR_TIMEOUT_MS=90000

# Auth (optional, off until APP_PASSWORD is set; only meaningful over HTTPS).
# SESSION_SECRET is required once APP_PASSWORD is set. API_TOKEN is for REST
# callers (Authorization: Bearer <token>). Generate a secret:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
APP_PASSWORD=
SESSION_SECRET=
API_TOKEN=

# WhatsApp "No LID for user" workaround (best-effort). Set to "off" to disable.
LID_WORKAROUND=on
